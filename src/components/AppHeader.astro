---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
---

<header class="header flex gap-[var(--sl-nav-gap)] justify-between items-center">
  <div class="overflow-clip p-1 -m-1 min-w-0 flex shrink-0">
    <a href="/" class="flex items-center gap-2 text-[length:var(--sl-text-lg)] font-bold text-[var(--sl-color-white)] no-underline whitespace-nowrap transition-colors hover:text-[var(--sl-color-accent)]">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round"
        aria-hidden="true" class="shrink-0">
        <polygon points="12 2 2 7 12 12 22 7 12 2"/>
        <polyline points="2 17 12 22 22 17"/>
        <polyline points="2 12 12 17 22 12"/>
      </svg>
      <span>Studio3xy</span>
    </a>
  </div>
  <div class="flex-1"></div>
  <div class="hidden md:flex gap-4 items-center">
    <Search />
    <ThemeToggle />
  </div>
</header>
