---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
---

<header class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <a href="/" class="site-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round"
        aria-hidden="true" class="site-logo">
        <polygon points="12 2 2 7 12 12 22 7 12 2"/>
        <polyline points="2 17 12 22 22 17"/>
        <polyline points="2 12 12 17 22 12"/>
      </svg>
      <span>Studio3xy</span>
    </a>
  </div>
  <div class="sl-flex"></div>
  <div class="right-group sl-hidden md:sl-flex">
    <Search />
    <ThemeToggle />
  </div>
</header>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
  }

  .title-wrapper {
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-text-lg);
    font-weight: 700;
    color: var(--sl-color-white);
    text-decoration: none;
    white-space: nowrap;
  }
  .site-title:hover { color: var(--sl-color-accent); }

  .site-logo { flex-shrink: 0; }

  .right-group { gap: 1rem; align-items: center; }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    .header {
      --__sidebar-width: max(0rem, var(--sl-sidebar-width) - var(--sl-nav-pad-x));
      display: grid;
      grid-template-columns:
        minmax(var(--__sidebar-width), auto)
        1fr
        auto;
      align-content: center;
    }
  }
</style>
