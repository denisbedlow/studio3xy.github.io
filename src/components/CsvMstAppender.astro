---
---

<div class="csv-tool">
  <div
    id="drop-zone"
    class="drop-zone"
    tabindex="0"
    role="button"
    aria-label="Drop a CSV file here or click to browse"
  >
    <svg class="upload-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="17 8 12 3 7 8"/>
      <line x1="12" y1="3" x2="12" y2="15"/>
    </svg>
    <p class="drop-primary">Drop your CSV file here</p>
    <p class="drop-secondary">or <label for="file-input" class="browse-link">browse files</label></p>
    <input type="file" id="file-input" accept=".csv" />
  </div>

  <div id="status" class="status" role="status" aria-live="polite"></div>
</div>

<script>
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const statusEl = document.getElementById('status')!;

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone.addEventListener('dragleave', (e) => {
    if (!dropZone.contains(e.relatedTarget as Node)) {
      dropZone.classList.remove('drag-over');
    }
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer?.files[0];
    if (file) processFile(file);
  });

  dropZone.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('label')) fileInput.click();
  });

  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) processFile(fileInput.files[0]);
  });

  function processFile(file: File) {
    if (!file.name.toLowerCase().endsWith('.csv')) {
      showStatus('error', 'Please provide a .csv file.');
      return;
    }
    showStatus('loading', 'Processing…');
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const rows = parseCSV(e.target!.result as string);
        const transformed = transformCSV(rows);
        const output = serializeCSV(transformed);
        downloadCSV(output, file.name);
        showStatus('success', `Done — downloading as ${outputFilename(file.name)}`);
      } catch (err) {
        showStatus('error', (err as Error).message);
      }
    };
    reader.readAsText(file);
  }

  function parseCSV(text: string): string[][] {
    const rows: string[][] = [];
    let row: string[] = [];
    let field = '';
    let inQuotes = false;
    let i = 0;

    text = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');

    while (i < text.length) {
      const ch = text[i];
      if (inQuotes) {
        if (ch === '"' && text[i + 1] === '"') { field += '"'; i += 2; }
        else if (ch === '"') { inQuotes = false; i++; }
        else { field += ch; i++; }
      } else {
        if (ch === '"') { inQuotes = true; i++; }
        else if (ch === ',') { row.push(field); field = ''; i++; }
        else if (ch === '\n') {
          row.push(field); field = '';
          if (row.some(f => f !== '')) rows.push(row);
          row = []; i++;
        } else { field += ch; i++; }
      }
    }

    if (field !== '' || row.length > 0) {
      row.push(field);
      if (row.some(f => f !== '')) rows.push(row);
    }

    return rows;
  }

  function transformCSV(rows: string[][]): string[][] {
    if (rows.length === 0) throw new Error('CSV file is empty.');

    const headers = rows[0];
    const subtitleIdx = headers.findIndex(h => h.trim() === 'Subtitle');
    if (subtitleIdx === -1) throw new Error('"Subtitle" column not found. Check the file headers.');

    const newRows: string[][] = [headers];

    for (let i = 1; i < rows.length; i++) {
      const row = [...rows[i]];
      row[subtitleIdx] = (row[subtitleIdx] ?? '') + '_MST';
      newRows.push(row);
    }

    return newRows;
  }

  function serializeCSV(rows: string[][]): string {
    return rows.map(row =>
      row.map(field => {
        const s = String(field ?? '');
        return (s.includes(',') || s.includes('"') || s.includes('\n'))
          ? '"' + s.replace(/"/g, '""') + '"'
          : s;
      }).join(',')
    ).join('\n');
  }

  function outputFilename(original: string): string {
    const dot = original.lastIndexOf('.');
    return dot !== -1
      ? original.slice(0, dot) + '_modified' + original.slice(dot)
      : original + '_modified';
  }

  function downloadCSV(content: string, originalFilename: string) {
    const blob = new Blob([content], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = outputFilename(originalFilename);
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function showStatus(type: 'loading' | 'success' | 'error', message: string) {
    statusEl.className = `status status--${type}`;
    statusEl.textContent = message;
  }
</script>

<style>
  .csv-tool {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .drop-zone {
    border: 2px dashed var(--sl-color-gray-4);
    border-radius: 0.75rem;
    padding: 3rem 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    background-color: var(--sl-color-gray-7, #f8f9fa);
    user-select: none;
  }

  .drop-zone:hover,
  .drop-zone:focus-visible,
  .drop-zone.drag-over {
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low);
    outline: none;
  }

  .upload-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--sl-color-gray-3);
    margin: 0 auto 1rem;
    display: block;
    transition: color 0.2s ease;
  }

  .drop-zone:hover .upload-icon,
  .drop-zone.drag-over .upload-icon {
    color: var(--sl-color-accent);
  }

  .drop-primary {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sl-color-text);
    margin: 0 0 0.25rem;
  }

  .drop-secondary {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .browse-link {
    color: var(--sl-color-accent);
    text-decoration: underline;
    cursor: pointer;
  }

  input[type="file"] {
    display: none;
  }

  .status {
    display: none;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    padding: 0.6rem 0.875rem;
  }

  .status--loading {
    display: block;
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6, #e9ecef);
  }

  .status--success {
    display: block;
    color: #16a34a;
    background: rgba(22, 163, 74, 0.1);
    border: 1px solid rgba(22, 163, 74, 0.25);
  }

  .status--error {
    display: block;
    color: #dc2626;
    background: rgba(220, 38, 38, 0.1);
    border: 1px solid rgba(220, 38, 38, 0.25);
  }
</style>
