<!-- Search button + modal dialog powered by Pagefind.
     Uses <dialog> so the modal lands in the browser's top layer — no stacking
     context or z-index conflicts with the fixed header or sidebars. -->

<button id="search-open" class="flex items-center justify-center w-8 h-8 border-none rounded bg-transparent text-[var(--sl-color-gray-3)] cursor-pointer p-0 transition-colors duration-150 hover:text-[var(--sl-color-white)] hover:bg-[var(--sl-color-gray-5)]" aria-label="Search" title="Search">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<dialog id="search-dialog" aria-label="Search" class="search-dialog mt-[10vh] w-[min(640px,90vw)] max-h-[80vh] overflow-y-auto bg-[var(--sl-color-bg)] border border-[var(--sl-color-hairline)] rounded-lg p-4 text-[var(--sl-color-text)]">
  <div id="pagefind-container"></div>
</dialog>

<!-- is:inline required — runs verbatim in browser, Vite does not intercept the
     dynamic import. This lets the try/catch handle dev-mode 404 gracefully. -->
<script is:inline>
  function setup() {
    const btn    = document.getElementById('search-open');
    const dialog = document.getElementById('search-dialog');
    if (!btn || !dialog) return;

    btn.addEventListener('click', async () => {
      dialog.showModal();

      const container = dialog.querySelector('#pagefind-container');
      if (container && !container.hasChildNodes()) {
        try {
          const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
          new PagefindUI({ element: container, showSubResults: true, resetStyles: false });
        } catch (err) {
          console.error('Pagefind failed to load:', err);
          container.textContent = 'Search not available in dev mode — run npm run build first.';
        }
      }

      setTimeout(() => {
        dialog.querySelector('input[type="text"]')?.focus();
      }, 60);
    });

    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      if (
        e.clientX < rect.left || e.clientX > rect.right ||
        e.clientY < rect.top  || e.clientY > rect.bottom
      ) dialog.close();
    });
  }

  setup();
  document.addEventListener('astro:page-load', setup);
</script>
