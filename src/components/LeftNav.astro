---
const pathname = Astro.url.pathname;
const current = pathname.endsWith('/') ? pathname : pathname + '/';

type NavItem = { label: string; href: string };
type NavGroup = { label: string; items: NavItem[]; collapsed?: boolean };
type NavEntry = NavItem | NavGroup;

const nav: NavEntry[] = [
  { label: 'Welcome',      href: '/' },
  { label: 'Eye Tracking', href: '/eyetracking/' },
  { label: 'Video',        href: '/video/' },
  {
    label: 'Tools',
    items: [
      { label: 'CSV Loc Name Decomposer', href: '/tools/csv-decomposer/' },
      { label: 'CSV Column Splitter',     href: '/tools/csv-rule-splitter/' },
      { label: 'EDL Tool & Converter',    href: '/tools/edl-converter/' },
      { label: 'CSV Add _MST to VFX ID',  href: '/tools/csv-mst-appender/' },
    ],
  },
];

function isActive(href: string) {
  return href === '/' ? current === '/' : current.startsWith(href);
}

function isGroup(entry: NavEntry): entry is NavGroup {
  return 'items' in entry;
}
---

<nav class="sidebar-content" aria-label="Main navigation">
  <ul class="top-level">
    {nav.map((entry) =>
      isGroup(entry) ? (
        <li class="nav-group">
          <details open>
            <summary class="group-label">
              <span>{entry.label}</span>
              <svg class="caret" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <ul class="sub-list">
              {entry.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                    class:list={['nav-link', { active: isActive(item.href) }]}
                  >{item.label}</a>
                </li>
              ))}
            </ul>
          </details>
        </li>
      ) : (
        <li>
          <a
            href={(entry as NavItem).href}
            aria-current={isActive((entry as NavItem).href) ? 'page' : undefined}
            class:list={['nav-link', { active: isActive((entry as NavItem).href) }]}
          >{(entry as NavItem).label}</a>
        </li>
      )
    )}
  </ul>
</nav>

<script>
  const KEY_NAV_WIDTH = 'sl-nav-width';
  const NAV_MIN = 160;
  const NAV_MAX = 400;

  function setupNavResize() {
    if (window.innerWidth < 800) return;
    const sidebarPane = document.querySelector<HTMLElement>('.sidebar-pane');
    if (!sidebarPane || document.getElementById('nav-resize-handle')) return;

    const handle = document.createElement('div');
    handle.id = 'nav-resize-handle';
    Object.assign(handle.style, {
      position: 'absolute', right: '-6px', top: '0', bottom: '0',
      width: '12px', cursor: 'col-resize', zIndex: '30',
    });

    const line = document.createElement('div');
    Object.assign(line.style, {
      position: 'absolute', left: '5px', top: '0', bottom: '0',
      width: '2px', borderRadius: '1px', background: 'transparent',
      transition: 'background 0.15s', pointerEvents: 'none',
    });
    handle.appendChild(line);

    handle.addEventListener('mouseenter', () => { line.style.background = 'var(--sl-color-accent)'; });
    handle.addEventListener('mouseleave', () => {
      if (!document.body.classList.contains('nav-resizing')) line.style.background = 'transparent';
    });

    handle.addEventListener('mousedown', (e: MouseEvent) => {
      e.preventDefault();
      const startX = e.clientX;
      const startW = sidebarPane.getBoundingClientRect().width;
      document.body.classList.add('nav-resizing');

      function onMove(e: MouseEvent) {
        const w = Math.min(NAV_MAX, Math.max(NAV_MIN, startW + (e.clientX - startX)));
        document.documentElement.style.setProperty('--sl-sidebar-width', w + 'px');
      }
      function onUp() {
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        document.body.classList.remove('nav-resizing');
        line.style.background = handle.matches(':hover') ? 'var(--sl-color-accent)' : 'transparent';
        localStorage.setItem(KEY_NAV_WIDTH, String(Math.round(sidebarPane!.getBoundingClientRect().width)));
      }
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });

    sidebarPane.appendChild(handle);
  }

  setupNavResize();
  document.addEventListener('astro:page-load', setupNavResize);
</script>

<style>
  .sidebar-content { padding: 1rem var(--sl-sidebar-pad-x); }

  .top-level, .sub-list { list-style: none; margin: 0; padding: 0; }

  .top-level { display: flex; flex-direction: column; gap: 0.25rem; }

  .sub-list {
    margin-top: 0.25rem;
    padding-inline-start: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .nav-link {
    display: block;
    padding: 0.3125rem 0.5rem;
    border-radius: 0.25rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: background 0.1s, color 0.1s;
  }
  .nav-link:hover { background: var(--sl-color-gray-6); color: var(--sl-color-white); }
  .nav-link.active,
  .nav-link[aria-current='page'] {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-weight: 600;
  }

  .group-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3125rem 0.5rem;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    list-style: none;
    border-radius: 0.25rem;
    user-select: none;
  }
  .group-label::-webkit-details-marker { display: none; }
  .group-label:hover { background: var(--sl-color-gray-6); color: var(--sl-color-gray-2); }

  .caret { flex-shrink: 0; transition: transform 0.2s; }
  details[open] .caret { transform: rotate(180deg); }
</style>
