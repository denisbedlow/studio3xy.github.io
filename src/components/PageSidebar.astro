---
import type { MarkdownHeading } from 'astro';
import RightToc from './RightToc.astro';
import TocControls from './TocControls.svelte';

interface Props {
  headings: MarkdownHeading[];
  hasToc: boolean;
}

const { headings, hasToc } = Astro.props;
---

<!-- Mobile TOC — only when there are headings -->
{hasToc && (
  <div class="block lg:hidden">
    <details class="mobile-toc">
      <summary>On this page</summary>
      <RightToc {headings} />
    </details>
  </div>
)}

<!--
  toc-wrapper (and collapse/expand button) renders on ALL pages at desktop
  so users can always reclaim right-column width. TOC list only shows when
  there are headings.
-->
<div class="toc-wrapper hidden lg:block">
  <div id="toc-edge" class="toc-edge">
    <button
      id="toc-toggle"
      class="toc-toggle"
      aria-label="Toggle table of contents"
      title="Toggle table of contents"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14" height="14" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round"
        class="toc-chevron" aria-hidden="true"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  {hasToc && (
    <div class="right-sidebar-panel">
      <div class="toc-content sl-container">
        <RightToc {headings} />
      </div>
    </div>
  )}
</div>

<!-- Restores collapsed/width state before first paint — must stay inline to avoid flash -->
<script is:inline>
  (function () {
    var root = document.documentElement;

    if (localStorage.getItem('sl-toc-collapsed') === '1') {
      root.classList.add('toc-collapsed');
    }

    var nw = localStorage.getItem('sl-nav-width');
    if (nw) root.style.setProperty('--sl-sidebar-width', nw + 'px');

    var tw = localStorage.getItem('sl-toc-width');
    if (tw && localStorage.getItem('sl-toc-collapsed') !== '1') {
      root.style.setProperty('--toc-width', tw + 'px');
    }

    document.addEventListener('astro:before-swap', function (ev) {
      var tw2 = localStorage.getItem('sl-toc-width');
      if (tw2 && localStorage.getItem('sl-toc-collapsed') !== '1') {
        ev.newDocument.documentElement.style.setProperty('--toc-width', tw2 + 'px');
      }

      var nw2 = localStorage.getItem('sl-nav-width');
      if (nw2) ev.newDocument.documentElement.style.setProperty('--sl-sidebar-width', nw2 + 'px');

      if (localStorage.getItem('sl-toc-collapsed') === '1') {
        ev.newDocument.documentElement.classList.add('toc-collapsed');
      }

      ev.newDocument.documentElement.setAttribute('data-has-sidebar', '');
    });
  })();
</script>

<!-- Interactive TOC collapse/resize — Svelte island -->
<TocControls client:load />

<style is:global>
  @media (min-width: 72rem) {
    .right-sidebar-container,
    .right-sidebar { width: var(--toc-width) !important; }

    html.toc-collapsed .right-sidebar-container { width: 0 !important; }
    html.toc-collapsed .right-sidebar           { width: 0 !important; overflow: hidden !important; }

    .main-pane .sl-container {
      max-width: min(var(--sl-content-width), 82%) !important;
      margin-inline: auto !important;
    }

    body.toc-resizing,
    body.nav-resizing { user-select: none; cursor: col-resize; }
  }
</style>

<style>
  .toc-wrapper { position: relative; height: 100%; }

  .mobile-toc {
    padding: 0.75rem var(--sl-content-pad-x);
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .mobile-toc summary {
    font-size: var(--sl-text-sm); font-weight: 600;
    color: var(--sl-color-white); cursor: pointer;
    list-style: none; padding: 0.25rem 0;
  }
  .mobile-toc summary::-webkit-details-marker { display: none; }
  .mobile-toc[open] { padding-bottom: 1rem; }

  .toc-edge {
    position: absolute;
    left: -6px; top: 0; bottom: 0;
    width: 12px; cursor: col-resize; z-index: 30;
    display: none; flex-direction: column;
    align-items: center; justify-content: flex-start;
    padding-top: calc(var(--sl-nav-height) + 1.5rem);
  }
  @media (min-width: 72rem) { .toc-edge { display: flex; } }

  .toc-edge::before {
    content: ''; position: absolute;
    left: 5px; top: 0; bottom: 0;
    width: 2px; border-radius: 1px;
    background: transparent; transition: background 0.15s;
    pointer-events: none;
  }
  .toc-edge:hover::before,
  :global(body.toc-resizing) .toc-edge::before { background: var(--sl-color-accent); }

  .toc-toggle {
    view-transition-name: toc-toggle;
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    width: 1.5rem; height: 1.5rem;
    border-radius: 50%;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-3);
    cursor: pointer; padding: 0; flex-shrink: 0;
    box-shadow: var(--sl-shadow-sm); opacity: 0;
    transition: opacity 0.15s, background 0.15s, color 0.15s, border-color 0.15s;
  }
  .toc-edge:hover .toc-toggle,
  :global(body.toc-resizing) .toc-toggle { opacity: 1; }
  .toc-toggle:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
  }

  :global(html.toc-collapsed) .toc-edge {
    position: fixed; right: 0; left: auto;
    width: 1.75rem; cursor: default;
    padding-top: calc(2 * var(--sl-nav-height) + 1.5rem);
  }
  :global(html.toc-collapsed) .toc-edge::before { display: none; }
  :global(html.toc-collapsed) .toc-toggle {
    opacity: 1;
    border-radius: 6px 0 0 6px;
    border-right: none;
  }

  .toc-chevron { transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1); }
  :global(html.toc-collapsed) .toc-chevron { transform: rotate(180deg); }

  .right-sidebar-panel { padding: 1rem var(--sl-sidebar-pad-x); }

  .sl-container {
    width: calc(var(--toc-width) - 2 * var(--sl-sidebar-pad-x));
    transition: opacity 0.18s ease;
  }
  :global(html.toc-collapsed) .sl-container { opacity: 0; }
</style>
