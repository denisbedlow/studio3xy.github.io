---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => {
    const withoutExt   = entry.id.replace(/\.(md|mdx)$/, '');
    const withoutIndex = withoutExt.replace(/\/index$/, '');
    const slug = withoutIndex === 'index' ? undefined : withoutIndex || undefined;
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;

let Content: any;
let headings: any[] = [];
let renderError: string | null = null;

try {
  ({ Content, headings } = await render(entry));
} catch (err) {
  console.error('[...slug] render failed:', err);
  renderError = err instanceof Error ? err.message : String(err);
}
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description ?? ''}
  {headings}
  hasToc={headings.length > 0}
  hideTitle={entry.data.hideTitle}
>
  {renderError
    ? <p style="color:red">Failed to render content: {renderError}</p>
    : <Content />
  }
</DocsLayout>
