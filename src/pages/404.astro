---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page not found">
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:1rem;text-align:center;padding:2rem;">
    <h1 style="font-size:4rem;font-weight:700;color:var(--sl-color-white)">404</h1>
    <p style="color:var(--sl-color-gray-2)">Page not found.</p>
    <a href="/" style="color:var(--sl-color-accent-high);text-decoration:none">← Go home</a>
  </div>
</BaseLayout>
